rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match any document in the 'users' collection
    match /users/{userId} {
      // Allow read/write only if the request's auth.uid matches the document's userId
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Match any document in the 'assets' subcollection
      match /assets/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Match any document in the 'transactions' subcollection
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Match any document in the 'platforms' subcollection
      match /platforms/{platformId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
