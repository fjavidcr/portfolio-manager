{
  "name": "portfolio-manager",
  "version": "1.0.0",
  "description": "Portfolio manager",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy:app": "npm run build && firebase deploy --only hosting",
    "deploy:db:rules": "firebase deploy --only firestore:rules",
    "deploy:db:indexes": "firebase deploy --only firestore:indexes",
    "deploy:all": "npm run build && firebase deploy",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.cjs,.ts,.astro,.vue",
    "lint:fix": "eslint . --ext .js,.cjs,.ts,.astro,.vue --fix",
    "format": "prettier --write \"**/*.{js,cjs,ts,astro,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,cjs,ts,astro,vue,json,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "node scripts/seed_database.cjs",
    "users-list": "node scripts/list_users.cjs",
    "migrate-tx": "node scripts/migrate_transactions.cjs",
    "scan:secrets": "trufflehog git file://. && echo \"\" && trufflehog filesystem . --exclude-paths=.trufflehog-ignore",
    "prepare": "husky"
  },
  "author": "Francisco Javier del Castillo Ramírez <fj.delcastillo.ramirez@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@astrojs/vue": "^5.1.4",
    "@nanostores/vue": "^1.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "apexcharts": "^5.10.4",
    "astro": "^5.18.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "nanostores": "^1.1.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.26",
    "vue3-apexcharts": "^1.11.1"
  },
  "devDependencies": {
    "astro-eslint-parser": "^1.2.2",
    "daisyui": "^5.5.14",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.53.0",
    "vue-eslint-parser": "^10.2.0"
  }
}
