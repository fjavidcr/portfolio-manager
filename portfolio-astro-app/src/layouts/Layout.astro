---
import Sidebar from "@shared/components/Sidebar.astro";
import "@styles/global.css";

interface Props {
	title: string;
	requireAuth?: boolean;
}

const { title, requireAuth = false } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio Manager" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

        <script is:inline>
            // Theme Init
            const getThemePreference = () => {
                const STORAGE_KEY = 'theme_pref';
                if (typeof localStorage !== 'undefined' && localStorage.getItem(STORAGE_KEY)) {
                    return localStorage.getItem(STORAGE_KEY);
                }
                return 'system';
            };

            const applyTheme = () => {
                const pref = getThemePreference();
                if (pref === 'dark' || (pref === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            };

            applyTheme();

            // Listen for system changes
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                if (getThemePreference() === 'system') applyTheme();
            });
        </script>
	</head>
	<body class="bg-surface text-on-surface min-h-screen flex">
		<!-- Sidebar for Desktop -->
		<Sidebar />

		<div class="flex-1 flex flex-col md:pl-64 transition-all duration-300">
			<!-- Mobile Header -->
			<header
				class="md:hidden h-16 flex items-center px-4 border-b border-outline-variant bg-surface-container-low"
			>
				<button
					id="menu-btn"
					class="p-2 -ml-2 rounded-md hover:bg-surface-container-high"
				>
					<svg
						class="w-6 h-6"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						><path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M4 6h16M4 12h16M4 18h16"></path></svg
					>
				</button>
				<span class="ml-4 font-bold text-lg">Portfolio Manager</span>
                <div class="ml-auto">
                    <button id="theme-toggle-mobile" class="p-2 rounded-full hover:bg-surface-container-high transition-colors text-on-surface">
                         <svg id="mobile-light-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        <svg id="mobile-dark-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                        </svg>
                    </button>
                </div>
			</header>

			<main class="flex-1 max-w-7xl w-full mx-auto p-4 sm:p-6 lg:p-8">
				<slot />
			</main>
		</div>

		<script>
			// Mobile Menu Toggle
			const btn = document.getElementById("menu-btn");
			const sidebar = document.getElementById("sidebar");
			const overlay = document.getElementById("sidebar-overlay");

			btn?.addEventListener("click", () => {
				sidebar?.classList.toggle("-translate-x-full");
				sidebar?.classList.toggle("translate-x-0");
				overlay?.classList.remove("hidden");
			});

            // Mobile Theme Toggle
            const mobileBtn = document.getElementById('theme-toggle-mobile');

            // Using the same 3-state logic for mobile button click
            mobileBtn?.addEventListener('click', () => {
                const STORAGE_KEY = 'theme_pref';
                const current = localStorage.getItem(STORAGE_KEY) || 'system';
                let next = 'system';
                if (current === 'system') next = 'light';
                else if (current === 'light') next = 'dark';
                else if (current === 'dark') next = 'system';

                localStorage.setItem(STORAGE_KEY, next);

                if (next === 'dark' || (next === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }

                // Dispatch event so Sidebar updates if visible
                window.dispatchEvent(new Event('storage'));
            });
		</script>

		{requireAuth && (
			<script>
				import { user, authLoading } from "@features/auth/stores/authStore";

				const checkAuth = () => {
					const isLoginPage = window.location.pathname === '/login';

					if (!authLoading.get() && !user.get() && !isLoginPage) {
						window.location.href = "/login";
					}
				};

				authLoading.subscribe(checkAuth);
				user.subscribe(checkAuth);
			</script>
		)}
	</body>
</html>
