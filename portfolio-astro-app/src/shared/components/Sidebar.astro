---
import UserProfile from "@features/auth/components/UserProfile.vue";
---

<aside
    class="fixed inset-y-0 left-0 w-64 bg-surface-container-low text-on-surface border-r border-outline-variant transform transition-transform duration-300 md:translate-x-0 -translate-x-full z-30"
    id="sidebar"
>
    <div class="h-16 flex items-center px-6 border-b border-outline-variant">
        <h1
            class="text-xl font-bold bg-gradient-to-r from-primary to-primary-container bg-clip-text text-transparent"
        >
            Portfolio Manager
        </h1>
    </div>

    <nav class="p-4 space-y-2">
        <a
            href="/"
            class="flex items-center px-4 py-3 text-sm font-medium rounded-full transition-colors hover:bg-surface-container-high focus:bg-secondary-container focus:text-on-secondary-container"
            id="nav-dashboard"
        >
            <svg
                class="w-5 h-5 mr-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                ></path></svg
            >
            Dashboard
        </a>
        <a
            href="/assets"
            class="flex items-center px-4 py-3 text-sm font-medium rounded-full transition-colors hover:bg-surface-container-high focus:bg-secondary-container focus:text-on-secondary-container"
            id="nav-assets"
        >
            <svg
                class="w-5 h-5 mr-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path></svg
            >
            Assets
        </a>
        <a
            href="/transactions"
            class="flex items-center px-4 py-3 text-sm font-medium rounded-full transition-colors hover:bg-surface-container-high focus:bg-secondary-container focus:text-on-secondary-container"
            id="nav-transactions"
        >
            <svg
                class="w-5 h-5 mr-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
                ></path></svg
            >
            Transactions
        </a>
    </nav>

    <UserProfile client:only="vue" />
</aside>

<div
    class="fixed inset-0 bg-black bg-opacity-50 z-20 md:hidden hidden"
    id="sidebar-overlay"
>
</div>

<script>
    // Highlight current link
    const path = window.location.pathname;
    const links = {
        "/": "nav-dashboard",
        "/assets": "nav-assets",
        "/transactions": "nav-transactions",
    };

    // Simple matching logic
    let activeId = links["/"]; // Default
    if (path.includes("assets")) activeId = links["/assets"];
    else if (path.includes("transactions")) activeId = links["/transactions"];

    document
        .getElementById(activeId)
        ?.classList.add(
            "bg-secondary-container",
            "text-on-secondary-container",
        );

    // Mobile Overlay
    const overlay = document.getElementById("sidebar-overlay");
    const sidebar = document.getElementById("sidebar");

    overlay?.addEventListener("click", () => {
        sidebar?.classList.remove("translate-x-0");
        overlay.classList.add("hidden");
    });
</script>
