---
import Layout from '@layouts/Layout.astro'
import AddTransactionForm from '@features/transactions/components/AddTransactionForm.vue'

const transactionId = Astro.url.searchParams.get('id') || undefined
---

<Layout title="Edit Transaction - Portfolio Manager" requireAuth={true}>
  <div class="max-w-2xl mx-auto space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-semibold text-on-surface">Edit Transaction</h1>
    </div>

    <div class="bg-surface-container-low shadow rounded-2xl border border-outline-variant p-6">
      <AddTransactionForm client:load transactionId={transactionId} />
    </div>
  </div>
</Layout>
