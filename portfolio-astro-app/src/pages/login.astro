---
import AuthLayout from '@layouts/AuthLayout.astro'
import LoginButton from '@features/auth/components/LoginButton.vue'
---

<AuthLayout title="Login - Portfolio Manager">
    <div
        class="max-w-md w-full space-y-8 p-10 bg-surface-container-low rounded-xl shadow-lg border border-outline-variant"
    >
        <div class="text-center">
            <h2 class="mt-6 text-3xl font-extrabold text-on-surface">
                Portfolio Manager
            </h2>
            <p class="mt-2 text-sm text-gray-400">
                Sign in to manage your investments
            </p>
        </div>
        <div class="mt-8 space-y-6">
            <div class="flex justify-center">
                <LoginButton client:load />
            </div>
        </div>
    </div>
</AuthLayout>
