---
import Layout from "@layouts/Layout.astro";
import DashboardView from "@features/portfolio/components/DashboardView.vue";
import { user } from "@features/auth/stores/authStore";

// Server-side guard (simple check, client-side is more robust for static site)
// If we were using SSR, we could check cookies/session here.
---

<Layout title="Dashboard">
    <DashboardView client:only="vue" />

    <script>
        import { user } from "../features/auth/stores/authStore";
        // Simple auth guard
        user.subscribe((u) => {
            if (u === null) {
                // Wait a bit to ensure it's not just initial load
                setTimeout(() => {
                    if (!user.get()) window.location.href = "/login";
                }, 500);
            }
        });
    </script>
</Layout>
