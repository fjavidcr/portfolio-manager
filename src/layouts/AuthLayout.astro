---
import '@styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio Manager Authentication" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script is:inline>
      // Theme Init - Multi-Theme Support (Consistent with Layout.astro)
      const getThemePreferences = () => {
        const STORAGE_KEY_COLOR = 'color_theme'
        const STORAGE_KEY_MODE = 'theme_mode'

        const colorTheme = localStorage.getItem(STORAGE_KEY_COLOR) || 'default'
        const mode = localStorage.getItem(STORAGE_KEY_MODE) || 'system'

        return { colorTheme, mode }
      }

      const applyTheme = () => {
        const { colorTheme, mode } = getThemePreferences()

        // Determine if dark mode
        const isDark =
          mode === 'dark' ||
          (mode === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)

        // Combine: "blue-light", "green-dark", etc.
        const fullTheme = `${colorTheme}-${isDark ? 'dark' : 'light'}`

        // Set data-theme attribute
        document.documentElement.setAttribute('data-theme', fullTheme)

        // Keep .dark class for backward compatibility
        document.documentElement.classList.toggle('dark', isDark)
      }

      applyTheme()

      // Listen for system changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        const { mode } = getThemePreferences()
        if (mode === 'system') applyTheme()
      })
    </script>
  </head>
  <body
    class="bg-surface text-on-surface min-h-screen flex items-center justify-center p-4 relative"
  >
    <!-- Theme Toggle -->
    <button
      id="theme-toggle"
      class="absolute top-4 right-4 p-2 rounded-full hover:bg-surface-container-high transition-colors text-on-surface focus:outline-none focus:ring-2 focus:ring-primary cursor-pointer"
      title="Toggle Theme"
      aria-label="Toggle color theme mode"
    >
      <!-- Sun (Light) -->
      <svg
        id="theme-icon-light"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
        ></path>
      </svg>
      <!-- Moon (Dark) -->
      <svg
        id="theme-icon-dark"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
        ></path>
      </svg>
      <!-- Computer (System) -->
      <svg
        id="theme-icon-system"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        ></path>
      </svg>
    </button>

    <slot />

    <!-- Inverse Auth Guard: If logged in, go to Dashboard -->
    <script>
      import { user, authLoading } from '@features/auth/stores/authStore'
      import {
        initThemeListeners,
        cycleThemeMode,
        getThemePreferences,
        subscribe
      } from '@shared/controllers/themeController'

      const checkAuth = () => {
        // If not loading AND we have a user, redirect to home
        if (!authLoading.get() && user.get()) {
          window.location.href = '/'
        }
      }

      authLoading.subscribe(checkAuth)
      user.subscribe(checkAuth)

      // Theme Toggle Logic
      const themeToggleBtn = document.getElementById('theme-toggle')
      const iconLight = document.getElementById('theme-icon-light')
      const iconDark = document.getElementById('theme-icon-dark')
      const iconSystem = document.getElementById('theme-icon-system')

      const updateThemeUI = () => {
        const { mode } = getThemePreferences()

        // Hide all
        iconLight?.classList.add('hidden')
        iconDark?.classList.add('hidden')
        iconSystem?.classList.add('hidden')

        if (mode === 'light') {
          iconLight?.classList.remove('hidden')
        } else if (mode === 'dark') {
          iconDark?.classList.remove('hidden')
        } else {
          iconSystem?.classList.remove('hidden')
        }
      }

      // Init Theme Listeners
      initThemeListeners()
      subscribe(updateThemeUI)
      // Initial UI update
      updateThemeUI()

      themeToggleBtn?.addEventListener('click', () => {
        cycleThemeMode()
      })
    </script>
  </body>
</html>
