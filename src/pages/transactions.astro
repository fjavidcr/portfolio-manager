---
import Layout from '@layouts/Layout.astro'
import TransactionList from '@features/transactions/components/TransactionList.vue'
---

<Layout title="Transactions - Portfolio Manager" requireAuth={true}>
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-semibold text-on-surface">Transactions</h1>
      <a
        href="/add-transaction"
        class="bg-primary hover:bg-primary-container hover:text-on-primary-container text-on-primary transitions-colors duration-200 px-4 py-2 rounded-md text-sm font-medium"
      >
        Add Transaction
      </a>
    </div>

    <TransactionList client:load />
  </div>
</Layout>
