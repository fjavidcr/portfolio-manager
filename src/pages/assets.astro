---
import Layout from '@layouts/Layout.astro'
import AssetTable from '@features/assets/components/AssetTable.vue'
---

<Layout title="Assets - Portfolio Manager" requireAuth={true}>
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-semibold text-on-surface">Assets</h1>
      <a
        href="/add-asset"
        class="bg-primary hover:bg-primary-container hover:text-on-primary-container text-on-primary transitions-colors duration-200 px-4 py-2 rounded-md text-sm font-medium"
      >
        Add Asset
      </a>
    </div>

    <AssetTable client:load />
  </div>
</Layout>
