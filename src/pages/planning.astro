---
import Layout from '@layouts/Layout.astro'
import DcaSummary from '@features/planning/components/DcaSummary.vue'
import DcaGoalList from '@features/planning/components/DcaGoalList.vue'
import DcaAssetAllocation from '@features/planning/components/DcaAssetAllocation.vue'
---

<Layout title="Planificación - Portfolio Manager" requireAuth={true}>
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-on-surface">Planificación DCA</h1>
        <p class="text-secondary mt-1 tracking-tight">Estrategia de inversión recurrente a largo plazo.</p>
      </div>

      <div class="flex items-center gap-2">
          <div class="badge badge-lg badge-primary font-bold">DCA: Largo Plazo</div>
      </div>
    </div>

    <div class="flex flex-col gap-10 animate-fade-in">
      
      <!-- Summary -->
      <DcaSummary client:load />

      <!-- Main Layout: Goals and Assets -->
      <div class="grid grid-cols-1 xl:grid-cols-3 gap-10 items-start">
        <!-- Left: Goals List -->
        <div class="xl:col-span-1">
            <DcaGoalList client:load />
        </div>

        <!-- Right: Assets Allocation -->
        <div class="xl:col-span-2">
            <DcaAssetAllocation client:load />
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
